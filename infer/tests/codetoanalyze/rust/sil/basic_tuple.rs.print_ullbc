# Final ULLBC before serialization:

// Full name: basic_tuple::main
fn main()
{
    let _0: (); // return
    let x_1: (i32, i32); // local
    let one_2: i32; // local
    let two_3: i32; // local
    let _4: i32; // anonymous local
    let _5: i32; // anonymous local

    bb0: {
        _0 = ();
        storage_live(x_1);
        x_1 = (const 1 : i32, const 2 : i32);
        storage_live(one_2);
        one_2 = copy x_1.0;
        storage_live(two_3);
        two_3 = copy x_1.1;
        storage_live(_4);
        _4 = copy two_3;
        x_1.0 = move _4;
        storage_dead(_4);
        storage_live(_5);
        _5 = copy one_2;
        x_1.1 = move _5;
        storage_dead(_5);
        _0 = ();
        storage_dead(two_3);
        storage_dead(one_2);
        storage_dead(x_1);
        return;
    }
}



