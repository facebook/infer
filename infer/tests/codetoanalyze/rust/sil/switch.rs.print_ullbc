        storage_live(_6);
        _6 = copy a_4;
        storage_live(_7);
        _7 = copy b_5;
        _8 = copy _6 panic.+ copy _7;
        _0 = move _8;
        storage_dead(_7);
        storage_dead(_6);
        storage_dead(b_5);
        storage_dead(a_4);
        return;
    }

    bb4: {
        storage_live(id_9);
        id_9 = copy (t_1 as variant Types::Named).id;
        _0 = copy id_9;
        storage_dead(id_9);
        return;
    }

    bb5: {
        undefined_behavior;
    }
}

// Full name: switch::main
fn main()
{
