    let @6: i32; // anonymous local
    let @7: i32; // anonymous local
    let @8: i32; // anonymous local
    let id@9: i32; // local

    bb0: {
        storage_live(@2);
        storage_live(@8);
        @2 := @discriminant(t@1);
        switch move (@2) -> 0 : isize: bb1, 1 : isize: bb2, 2 : isize: bb3, 3 : isize: bb4, otherwise: bb5;
    }

    bb1: {
        @0 := const (0 : i32);
        goto bb6;
    }

    bb2: {
        storage_live(v@3);
        v@3 := copy ((t@1 as variant Types::Value).0);
        @0 := copy (v@3);
        storage_dead(v@3);
        goto bb7;
    }

    bb3: {
        storage_live(a@4);
        a@4 := copy ((t@1 as variant Types::Tuple).0);
        storage_live(b@5);
        b@5 := copy ((t@1 as variant Types::Tuple).1);
        storage_live(@6);
        @6 := copy (a@4);
        storage_live(@7);
        @7 := copy (b@5);
        @8 := copy (@6) panic.+ copy (@7);
        @0 := move (@8);
        storage_dead(@7);
        storage_dead(@6);
        storage_dead(b@5);
        storage_dead(a@4);
        goto bb8;
    }

    bb4: {
        storage_live(id@9);
        id@9 := copy ((t@1 as variant Types::Named).id);
        @0 := copy (id@9);
        storage_dead(id@9);
        goto bb9;
    }

    bb5: {
        undefined_behavior;
    }

    bb6: {
        return;
    }

    bb7: {
        return;
    }

    bb8: {
        return;
    }

    bb9: {
        return;
    }
}

// Full name: switch::main
fn main()
{
