# Final ULLBC before serialization:

// Full name: switch::Types
enum Types {
  Unit,
  Value(i32),
  Tuple(i32, i32),
  Named(id: i32),
}

// Full name: switch::get_value
fn get_value(@1: Types) -> i32
{
    let @0: i32; // return
    let t@1: Types; // arg #1
    let @2: isize; // anonymous local
    let v@3: i32; // local
