# Final ULLBC before serialization:

// Full name: basic_if::main
fn main()
{
    let _0: (); // return
    let b_1: bool; // local
    let _2: bool; // anonymous local

    bb0: {
        _0 = ();
        storage_live(b_1);
        b_1 = const true;
        storage_live(_2);
        _2 = copy b_1;
        if move _2 -> bb1 else -> bb2;
    }

    bb1: {
        b_1 = const false;
        _0 = ();
        goto bb3;
    }

    bb2: {
        b_1 = const true;
        _0 = ();
        goto bb3;
    }

    bb3: {
        storage_dead(_2);
        storage_dead(b_1);
        return;
    }
}



