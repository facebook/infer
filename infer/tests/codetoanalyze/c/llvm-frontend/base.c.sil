}

define call_add1(var1: *int, var2: int) : int {
  local y: *ptr_elt, ptr: *ptr_elt
  #:
      n1 = load &var1
      store &ptr <- n1
      n2 = load &var2
      store &y <- n2
      n3 = load &ptr
      n4 = load n3
      n5 = load &y
      n6 = add(n4, n5)
      jmp 8::ret
      
  #8::ret:
      ret n6
      
}

define call_add() : int {
  #:
      n1 = add(1, 2)
      jmp 1::ret
      
  #1::ret:
      ret n1
      
}

declare bar() : *ptr_elt

define add(var1: int, var2: int) : int {
  local n2: *ptr_elt, n1: *ptr_elt
  #:
      n1 = load &var1
      store &n1 <- n1
      n2 = load &var2
      store &n2 <- n2
      n3 = load &n1
      n4 = load &n2
      ret __sil_plusa_int(n3, n4)
      
}

