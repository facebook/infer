define test17(var1: int) : int {
  local z: *ptr_elt, b: *ptr_elt
  #:
      n1 = load &var1
      store &b <- n1
      n2 = load &b
      n5 = __sil_ne(n2, 0)
      store &z <- (if n5 then 1 else 0)
      n7 = load &z
      ret n7
      
}

define test16(var1: *Person, var2: *Cat) : int {
  local person: *ptr_elt, cat: *ptr_elt, age: *ptr_elt
  #:
      n1 = load &var1
      store &person <- n1
      n2 = load &var2
      store &cat <- n2
      n3 = load &cat
      store n3.struct::Cat.field_1 <- 10
      n6 = load &person
      store n6.struct::Person.field_2 <- 30
      n9 = load &person
      store n9.struct::Person.field_0 <- "John"
      n12 = load &cat
      n13 = load &person
      store n13.struct::Person.field_4 <- n12
      n16 = load &person
      n17 = load n16.struct::Person.field_4
      n19 = load n17.struct::Cat.field_1
      store &age <- n19
      n22 = load &age
      if __sil_ne(n22, 10) then jmp 24 else jmp 23
      
  #23:
      _ = __sil_assert_fail(null)
      jmp __assert_fail::void::ret
      
  #24:
      n25 = load &age
      ret n25
      
  #__assert_fail::void::ret:
      unreachable
      
}

define test15() : int {
  local person: *ptr_elt, age: *ptr_elt
  #:
      _ = $builtins.memcpy(&person, &__const::test15::person, 32, 0)
      n1 = get_age(&person)
      jmp 3::ret
      
  #3::ret:
      store &age <- n1
      n3 = load &age
      if __sil_ne(n3, 30) then jmp 8 else jmp 7
      
  #7:
      _ = __sil_assert_fail(null)
      jmp __assert_fail::void::ret
      
  #8:
      n6 = load &age
      ret n6
      
  #__assert_fail::void::ret:
      unreachable
      
}

define test14() : int {
  local var2: *ptr_elt, person: *ptr_elt, age: *ptr_elt
  #:
      n1 = __sil_malloc(<int>)
      store &person <- n1
      n3 = load &person
      if __sil_ne(n3, null) then jmp 7 else jmp 21
      
  #13::ret:
      store &age <- n16
      n18 = load &person
      _ = __sil_free(n18)
      n19 = load &age
      if __sil_ne(n19, 30) then jmp 19 else jmp 18
      
  #18:
      _ = __sil_assert_fail(null)
      jmp __assert_fail::void::ret
      
  #19:
      n22 = load &age
      store &var2 <- n22
      jmp 22
      
  #21:
      store &var2 <- 0
      jmp 22
      
  #22:
      n7 = load &var2
      ret n7
      
  #7:
      n9 = load &person
      store n9.struct::Person.field_2 <- 30
      n12 = load &person
      store n12.struct::Person.field_0 <- "John"
      n15 = load &person
      n16 = get_age(n15)
      jmp 13::ret
      
  #__assert_fail::void::ret:
      unreachable
      
}

define test13() : int {
  local i: *ptr_elt
  #:
      store &i <- 10
      jmp 2
      
  #12:
      _ = __sil_assert_fail(null)
      jmp __assert_fail::void::ret
      
  #13:
      n8 = load &i
      ret n8
      
  #2:
      n2 = load &i
      if __sil_ge(n2, 8) then jmp 5 else jmp 8
      
  #5:
      n10 = load &i
      store &i <- __sil_plusa_int(n10, -1)
      jmp 2
      
  #8:
      n5 = load &i
      if __sil_ne(n5, 7) then jmp 13 else jmp 12
      
  #__assert_fail::void::ret:
      unreachable
      
}

define test12() : void {
