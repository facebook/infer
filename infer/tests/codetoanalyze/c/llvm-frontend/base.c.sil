define test9() : int {
  local ret: *ptr_elt, ptr: *ptr_elt
  #:
      n1 = __sil_malloc(<int>)
      store &ptr <- n1
      n3 = load &ptr
      store n3 <- 42
      n5 = load &ptr
      n6 = load n5
      store &ret <- n6
      n8 = load &ptr
      _ = __sil_free(n8)
      n9 = load &ret
      ret n9
      
}

define test8(var1: *int) : int {
  local var3: *ptr_elt, ret: *ptr_elt, ptr: *ptr_elt, null_ptr: *ptr_elt
  #:
      n1 = load &var1
      store &ptr <- n1
      n2 = load &ptr
      store n2 <- 1
      store &null_ptr <- null
      n5 = load &ptr
      n6 = call_add1(n5, 2)
      jmp 8::ret
      
  #11:
      n14 = load &null_ptr
      n15 = load n14
      store &var3 <- n15
      jmp 15
      
  #14:
      store &var3 <- 0
      jmp 15
      
  #15:
      n12 = load &var3
      ret n12
      
  #8::ret:
      store &ret <- n6
      n8 = load &ret
      if __sil_eq(n8, 3) then jmp 11 else jmp 14
      
}

