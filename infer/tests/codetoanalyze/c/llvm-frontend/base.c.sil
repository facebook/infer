define test10() : int {
  local sum: *ptr_elt, i: *ptr_elt
  #:
      store &sum <- 0
      store &i <- 0
      jmp 3
      
  #10:
      n16 = load &i
      store &i <- __sil_plusa_int(n16, 1)
      jmp 3
      
  #13:
      n6 = load &sum
      if __sil_ne(n6, 3) then jmp 18 else jmp 17
      
  #17:
      _ = __sil_assert_fail(null)
      jmp __assert_fail::void::ret
      
  #18:
      n9 = load &sum
      ret n9
      
  #3:
      n3 = load &i
      if __sil_lt(n3, 3) then jmp 6 else jmp 13
      
  #6:
      n11 = load &i
      n12 = load &sum
      store &sum <- __sil_plusa_int(n12, n11)
      jmp 10
      
  #__assert_fail::void::ret:
      unreachable
      
}

