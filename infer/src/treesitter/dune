(library
 (name TreeSitterFrontend)
 (public_name infer.TreeSitterFrontend)
 (no_dynlink)
 (c_library_flags (-lTreeSitterFrontend_stubs))
 (flags
  (:standard
   -open
   Core
   -open
   IStdlib
   -open
   IStd
   -open
   IBase
   -open
   Textuallib
   -open
   IR))
 (libraries core xmlm IStdlib IBase IR Textuallib)
 (foreign_stubs
  (language c)
  (names tree_sitter_stubs tree_sitter_runtime tree_sitter_c_grammar)
  (flags
   (:include c_flags.sexp)))
 (preprocess
  (pps ppx_compare)))

; Generate -I paths pointing to vendored tree-sitter sources.
; (source_tree vendor) ensures dune tracks the vendor files as dependencies.

(rule
 (target c_flags.sexp)
 (deps
  (source_tree vendor))
 (action
  (with-stdout-to
   %{target}
   (progn
    (echo "(-I ")
    (echo %{project_root})
    (echo "/src/treesitter/vendor/tree-sitter/include -I ")
    (echo %{project_root})
    (echo "/src/treesitter/vendor/tree-sitter/src -I ")
    (echo %{project_root})
    (echo "/src/treesitter/vendor/tree-sitter-c/src -std=c11 -fPIC -w)")))))
