type json_ast <ocaml module="Yojson.Safe" t="t"> = abstract

type semdiff_file = {
  filename: string;
  source: string;
  ast: json_ast;
}

type semdiff_pair = {
  previous: semdiff_file;
  current: semdiff_file;
}

type semdiff_input = {
  language: string;
  pairs: semdiff_pair list;
}
