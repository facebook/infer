(* Auto-generated JSON schema for specialized call graph export. *)

type loc = {
  file: string;
  line: int;
  col: int;
}

type callee = {
  callee_name: string;
  callee_context: int;
  call_location: loc;
}

type caller = {
  caller_name: string;
  caller_context: int;
}

type node = {
  caller: caller;
  ~callees <ocaml default="[]">: callee list;
}

type specialization = string

type call_graph = {
  nodes: node list;
  contexts: specialization list
}
